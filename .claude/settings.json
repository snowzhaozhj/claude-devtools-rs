{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pretooluse-bash.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/deny-edit-on-main.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/clippy-after-rs-edit.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/svelte-check-after-edit.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/fmt-after-rs-edit.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/validate-jsonl-fixture.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/invalidate-src-tauri-cache.sh"
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": ["ui/node_modules"]
  },
  "permissions": {
    "allow": [
      "Bash(git fetch:*)",
      "Bash(git checkout -b *)",
      "Bash(git branch -m *)",
      "Bash(git commit -m *)",
      "Bash(git commit --message *)",
      "Bash(git push -u origin *)",
      "Bash(git push origin *)",
      "Bash(git push)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)"
    ]
  }
}

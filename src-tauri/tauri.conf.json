{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude DevTools",
  "version": "0.4.0",
  "identifier": "com.zhaohejie.claude-devtools",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix ../ui",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Claude DevTools",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/Library/Caches/claude-devtools-rs/**",
          "$HOME/.cache/claude-devtools-rs/**",
          "$LOCALAPPDATA/claude-devtools-rs/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/snowzhaozhj/claude-devtools-rs/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCOTlDNTY3OEFBNzcxODkKUldTSmNhZUtaOFdaYTB0dHgxelo5MUJQYkg3NkhlYkpGY29SUEZPT3dheTZFN3hMcDJSRGdVNy8K"
    }
  }
}
